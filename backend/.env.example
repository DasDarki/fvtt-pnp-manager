PORT=8080
DATABASE_URL=postgres://aetherwright:aetherwright@localhost:5432/aetherwright?sslmode=disable
JWT_SECRET=dev-secret-change-me
# Schlüssel zum Verschlüsseln der BYOK-Bild-KI-Keys (Default: JWT_SECRET)
ENCRYPTION_KEY=
ACCESS_TTL=15m
REFRESH_TTL=720h
CORS_ORIGINS=http://localhost:3000
# BYOK läuft pro Benutzer in der App (Einstellungen → Bild-Provider).
# OPENAI_API_KEY ist nur optionaler globaler Fallback (leer = Mock-Bilder).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://localhost:8080
