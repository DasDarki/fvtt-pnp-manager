# --- Datenbank ---
POSTGRES_USER=aetherwright
POSTGRES_PASSWORD=change-me
POSTGRES_DB=aetherwright

# --- Sicherheit ---
JWT_SECRET=change-me-to-a-long-random-secret
# Verschlüsselt die BYOK-Bild-KI-Keys in der DB (Default: JWT_SECRET)
ENCRYPTION_KEY=

# --- Öffentliche URLs (vom Browser erreichbar!) ---
# PUBLIC_APP_URL = Frontend-Origin (auch als CORS-Origin genutzt).
# PUBLIC_API_URL = externe Basis-URL des Backends INKL. evtl. Proxy-Pfad (z.B. .../api).
#   Frontend ruft  ${PUBLIC_API_URL}/v1/...   auf
#   Uploads liegen unter  ${PUBLIC_API_URL}/uploads/...
#   WS-Relay unter        ${PUBLIC_API_URL -> ws(s)}/ws/foundry
# Lokal:
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8080
# Produktion mit Pfad-Routing auf EINER Domain (Traefik strippt /api), z.B.:
# PUBLIC_APP_URL=https://pnp.dasdarki.de
# PUBLIC_API_URL=https://pnp.dasdarki.de/api
# (Alternativ getrennte Subdomain ohne Strip: PUBLIC_API_URL=https://api.pnp.dasdarki.de)

# --- Bild-KI ---
# BYOK läuft jetzt pro Benutzer in der App (Einstellungen → Bild-Provider).
# Jeder Nutzer hinterlegt dort seine eigenen Keys (verschlüsselt in der DB).
# Die folgenden Variablen sind nur ein optionaler globaler Fallback:
# gesetzt = OpenAI als Standard, leer = Mock-Platzhalterbilder.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
